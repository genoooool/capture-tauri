{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capture",
  "version": "0.1.0",
  "identifier": "com.administrator.capture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:7000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Capture - 截图美化",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "label": "main",
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {}
}
